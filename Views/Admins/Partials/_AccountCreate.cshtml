@model AdminCreateAccountVm

@{
    var emailVal = Model?.Email ?? "";
}

<div class="row g-3">
    <div class="col-12">
        <div class="alert alert-info mb-0">
            Step 1: Enter <b>Email</b> and verify OTP. Step 2: Fill account details.
        </div>
    </div>

    <div class="col-12" id="otpMsg"></div>

    <div class="col-md-8">
        <label class="form-label">Email</label>
        <input class="form-control" id="createEmail" name="Email" value="@emailVal" placeholder="user@example.com" />
        <div class="form-text">Any valid email is accepted (not limited to a company domain).</div>
    </div>
    <div class="col-md-4 d-flex align-items-end">
        <form data-admin-form="sendOtp" class="w-100">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Email" value="@emailVal" />
            <button class="btn btn-primary w-100" type="submit">Send OTP</button>
        </form>
    </div>

    <div class="col-md-8">
        <label class="form-label">OTP code</label>
        <input class="form-control" name="OtpCode" id="createOtp" disabled inputmode="numeric" placeholder="6-digit code" />
    </div>
    <div class="col-md-4 d-flex align-items-end">
        <form data-admin-form="verifyOtp" class="w-100">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Email" value="@emailVal" />
            <input type="hidden" name="OtpCode" id="createOtpShadow" value="" />
            <button class="btn btn-outline-primary w-100" type="submit" onclick="
                document.getElementById('createOtpShadow').value = document.getElementById('createOtp').value;
            ">Verify OTP</button>
        </form>
    </div>
</div>

<div id="createDetails" class="d-none mt-4">
    <form asp-controller="Admins" asp-action="AccountCreate" method="post" data-admin-form="create" novalidate>
        @Html.AntiForgeryToken()

        <input type="hidden" name="Email" value="@emailVal" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Name</label>
                <input class="form-control" name="Name" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Phone</label>
                <input class="form-control" name="Phone" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Role</label>
                <select class="form-select" name="Role">
                    <option value="admin">Admin</option>
                    <option value="manager" selected>Manager</option>
                    <option value="mechanic">Mechanic</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Status</label>
                <select class="form-select" name="Status">
                    <option value="active" selected>active</option>
                    <option value="inactive">inactive</option>
                    <option value="locked">locked</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Password</label>
                <input class="form-control" name="Password" type="password" autocomplete="new-password" />
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-end gap-2">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Create account</button>
        </div>
    </form>
</div>

<script>
    // Keep email in OTP forms in sync with input
    const emailInput = document.getElementById('createEmail');
    if (emailInput) {
        emailInput.addEventListener('input', () => {
            const v = emailInput.value;
            document.querySelectorAll('#adminOverlayBody form[data-admin-form="sendOtp"] input[name="Email"]').forEach(x => x.value = v);
            document.querySelectorAll('#adminOverlayBody form[data-admin-form="verifyOtp"] input[name="Email"]').forEach(x => x.value = v);
            document.querySelectorAll('#adminOverlayBody form[data-admin-form="create"] input[name="Email"]').forEach(x => x.value = v);
        });
    }
</script>

