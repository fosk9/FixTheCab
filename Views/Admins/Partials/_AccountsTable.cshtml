@model List<AdminAccountRowVm>

@Html.AntiForgeryToken()

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
        <tr>
            <th style="width:80px">ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
            <th style="width:260px" class="text-end">Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.EmployeeId</td>
                <td>
                    <div class="fw-semibold">@r.Name</div>
                    <div class="text-muted small">@r.Phone</div>
                </td>
                <td>@r.Email</td>
                <td><span class="badge text-bg-primary">@r.Role</span></td>
                <td>
                    @if (string.Equals(r.Status, "active", StringComparison.OrdinalIgnoreCase))
                    {
                        <span class="badge text-bg-success">active</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">@r.Status</span>
                    }
                </td>
                <td class="text-end">
                    <button class="btn btn-outline-primary btn-sm" data-admin-action="details" data-id="@r.EmployeeId">Details</button>
                    <button class="btn btn-outline-primary btn-sm" data-admin-action="edit" data-id="@r.EmployeeId">Edit</button>
                    <button class="btn btn-outline-danger btn-sm" data-admin-action="disable" data-id="@r.EmployeeId">Disable</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

