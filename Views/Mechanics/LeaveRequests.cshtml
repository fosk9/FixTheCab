@model List<PMPRacing.Models.LeaveRequest>
@{
    ViewData["Title"] = "Đăng ký nghỉ phép";
}

<div class="container py-4">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h2 class="fw-bold text-primary"><i class="bi bi-calendar-event me-2"></i> Nghỉ Phép Của Tôi</h2>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addLeaveModal">
                <i class="bi bi-plus-lg me-1"></i> Gửi đơn mới
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">Ngày nghỉ</th>
                            <th>Lý do</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Người duyệt</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr><td colspan="4" class="text-center py-5 text-muted">Bạn chưa có đơn nghỉ phép nào.</td></tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@(item.LeaveDate?.ToString("dd/MM/yyyy") ?? "...")</td>
                                <td>@item.Reason</td>
                                <td>
                                    @if (item.Status == "pending") { <span class="badge bg-secondary">Chờ duyệt</span> }
                                    else if (item.Status == "approved") { <span class="badge bg-success">Đã duyệt</span> }
                                    else { <span class="badge bg-danger">Từ chối</span> }
                                </td>
                                <td class="text-end pe-4">@(item.ApprovedByNavigation?.Name ?? "---")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-link text-decoration-none p-0"><i class="bi bi-arrow-left"></i> Quay lại Dashboard</a>
    </div>
</div>

<!-- Modal Thêm Đơn -->
<div class="modal fade" id="addLeaveModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold">Đăng ký nghỉ phép</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="leaveForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Chọn ngày nghỉ</label>
                        <input type="date" name="date" class="form-control" required min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Lý do nghỉ</label>
                        <textarea name="reason" class="form-control" rows="3" placeholder="Nhập lý do chi tiết..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light rounded-pill" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Gửi yêu cầu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            $('#leaveForm').submit(function(e) {
                e.preventDefault();
                const data = {
                    date: $('input[name="date"]').val(),
                    reason: $('textarea[name="reason"]').val()
                };
                
                $.post('/Mechanics/RequestLeave', data, function(res) {
                    if (res.ok) {
                        alert('Đã gửi đơn thành công!');
                        window.location.reload();
                    } else {
                        alert('Lỗi: ' + res.message);
                    }
                });
            });
        });
    </script>
}
