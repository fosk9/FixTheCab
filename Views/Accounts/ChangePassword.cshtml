@model ChangePasswordPageViewModel
@{
    ViewData["Title"] = "Change password";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">

        @if (TempData["OtpError"] is string otpError && !string.IsNullOrWhiteSpace(otpError))
        {
            <div class="alert alert-danger" role="alert">@otpError</div>
        }
        @if (TempData["OtpSent"] is string otpSent && !string.IsNullOrWhiteSpace(otpSent))
        {
            <div class="alert alert-success" role="alert">@otpSent</div>
        }

        <div class="card shadow-sm mb-3">
            <div class="card-body p-4">
                <h1 class="h4 mb-1">Get OTP</h1>
                <p class="text-muted mb-3">We will send a 6-digit OTP to your email to confirm password change.</p>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input class="form-control" value="@Model.Request.Email" readonly />
                </div>

                <form asp-controller="Accounts" asp-action="SendOtp" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">Send OTP</button>
                </form>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Change password</h2>

                <form asp-controller="Accounts" asp-action="ChangePassword" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Change.EmployeeId" />
                    <input type="hidden" asp-for="Change.Email" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Change.OtpCode" class="form-label"></label>
                        <input asp-for="Change.OtpCode" class="form-control" inputmode="numeric" autocomplete="one-time-code" />
                        <span asp-validation-for="Change.OtpCode" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Change.NewPassword" class="form-label"></label>
                        <input asp-for="Change.NewPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Change.NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Change.ConfirmNewPassword" class="form-label"></label>
                        <input asp-for="Change.ConfirmNewPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Change.ConfirmNewPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Update password</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

