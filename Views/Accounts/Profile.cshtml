@model PMPRacing.Models.Employee
@{
    ViewData["Title"] = "Profile";
    var img = string.IsNullOrWhiteSpace(Model.ProfileImagePath) ? "~/img/avatars/default.svg" : Model.ProfileImagePath;
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <img src="@Url.Content(img)" alt="Profile image" class="rounded-circle border" style="width:72px;height:72px;object-fit:cover;" />
                    <div>
                        <div class="h4 mb-0">@Model.Name</div>
                        <div class="text-muted">@Model.Role</div>
                    </div>
                </div>

                <dl class="row mb-0">
                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@Model.Email</dd>

                    <dt class="col-sm-3">Phone</dt>
                    <dd class="col-sm-9">@Model.Phone</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">@Model.Status</dd>
                </dl>

                <div class="mt-4">
                    <a asp-controller="Accounts" asp-action="EditProfile" class="btn btn-outline-primary">Edit profile</a>
                </div>
            </div>
        </div>
    </div>
</div>

