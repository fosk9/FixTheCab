@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot password";
}

<div class="row justify-content-center">
    <div class="col-12 col-sm-10 col-md-8 col-lg-6">
        @if (TempData["PasswordResetSuccess"] is string resetDone && !string.IsNullOrWhiteSpace(resetDone))
        {
            <div class="alert alert-success" role="alert">@resetDone</div>
        }

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h4 mb-1">Forgot password</h1>
                <p class="text-muted mb-4">Enter your email. We will send an OTP for password reset.</p>

                <form asp-action="ForgotPassword" asp-controller="Accounts" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Send OTP</button>
                </form>

                <div class="text-center mt-3">
                    <a asp-controller="Accounts" asp-action="Login">Back to login</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
