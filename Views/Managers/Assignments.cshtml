@{
    ViewData["Title"] = "Phân Công Việc";
}

@await Html.PartialAsync("Partials/_ManagerNav")

<div class="row">
    <div class="col-md-7">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-list-task me-2 text-primary"></i> Xe Đang Chờ Phân Công</h5>
            </div>
            <div class="card-body p-0">
                <div id="pendingTableContainer" class="position-relative" style="min-height:200px">
                    <div class="d-flex justify-content-center p-5">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-5">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-person-workspace me-2 text-success"></i> Năng Suất Hiện Tại</h5>
                <button class="btn btn-sm btn-outline-secondary" onclick="loadWorkload()">
                    <i class="bi bi-arrow-clockwise"></i> Làm mới
                </button>
            </div>
            <div class="card-body p-0">
                <div id="workloadTableContainer" class="position-relative" style="min-height:200px">
                    <div class="d-flex justify-content-center p-5">
                        <div class="spinner-border text-success" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="assignModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header border-0 bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-wrench me-2"></i> Giao Việc Cho Thợ</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="assignForm">
                <div class="modal-body p-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="ReceiptId" name="receiptId" />
                    
                    <div class="alert alert-info border-0">
                        <strong>Mã tiếp nhận: <span id="lblReceiptId"></span></strong><br />
                        Khách hàng: <span id="lblCustomer"></span> (<span id="lblPhone"></span>)<br />
                        Xe: <span id="lblBike"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Chọn Thợ Đảm Nhận *</label>
                        <select id="MechanicId" name="mechanicId" class="form-select" required>
                            <option value="">-- Chọn thợ cơ khí --</option>
                            <!-- Options populated via JS -->
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Ghi Chú Giao Việc</label>
                        <textarea id="Note" name="note" class="form-control" rows="2" placeholder="Ghi chú thêm..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary" id="btnAssign"><i class="bi bi-check-circle me-1"></i> Xác Nhận Giao</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentMechanics = [];

        $(function () {
            loadPending();
            loadWorkload();

            $('#assignForm').on('submit', function (e) {
                e.preventDefault();
                
                const mechanicId = $('#MechanicId').val();
                if (!mechanicId) {
                    alert('Vui lòng chọn thợ!');
                    return;
                }

                const btn = $('#btnAssign');
                const origText = btn.html();
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Đang giao...');

                $.post('/Managers/AssignMechanic', $(this).serialize())
                    .done(function (res) {
                        if (res.ok) {
                            $('#assignModal').modal('hide');
                            // Reload both tables
                            loadPending();
                            loadWorkload();
                        }
                    })
                    .fail(function (xhr) {
                        alert(xhr.responseText || "Có lỗi xảy ra, vui lòng thử lại.");
                        btn.prop('disabled', false).html(origText);
                    });
            });
        });

        function loadPending() {
            $.get('/Managers/PendingTable')
                .done(function (html) {
                    $('#pendingTableContainer').html(html);
                });
        }

        function loadWorkload() {
            $.get('/Managers/WorkloadTable')
                .done(function (html) {
                    $('#workloadTableContainer').html(html);
                    
                    // Extract mechanics to populate the select dropdown for quick assignment
                    currentMechanics = [];
                    $(html).find('tr[data-mechanic-id]').each(function() {
                        const id = $(this).data('mechanic-id');
                        const name = $(this).find('td:first').text().trim();
                        const jobs = parseInt($(this).find('.badge').text().trim() || 0);
                        currentMechanics.push({ id, name, jobs });
                    });
                });
        }

        function openAssignModal(receiptId, customerName, phone, bikeInfo) {
            $('#ReceiptId').val(receiptId);
            $('#lblReceiptId').text(receiptId);
            $('#lblCustomer').text(customerName);
            $('#lblPhone').text(phone);
            $('#lblBike').text(bikeInfo);
            $('#Note').val('');
            
            // Populate select
            const sel = $('#MechanicId');
            sel.empty();
            sel.append('<option value="">-- Chọn thợ cơ khí --</option>');
            currentMechanics.forEach(m => {
                sel.append(`<option value="${m.id}">${m.name} (Đang làm ${m.jobs} xe)</option>`);
            });

            $('#btnAssign').prop('disabled', false).html('<i class="bi bi-check-circle me-1"></i> Xác Nhận Giao');
            new bootstrap.Modal(document.getElementById('assignModal')).show();
        }
    </script>
}
