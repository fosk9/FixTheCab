@{
    ViewData["Title"] = "Kho Phụ Tùng";
}

@await Html.PartialAsync("Partials/_ManagerNav")

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam me-2"></i>Kho Phụ Tùng</h2>
    <button class="btn btn-primary" onclick="showCreatePartModal()">
        <i class="bi bi-plus-circle me-1"></i> Nhập Phụ tùng mới
    </button>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <div class="row align-items-center mb-3">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm phụ tùng...">
                </div>
            </div>
            <div class="col-md-7 text-end">
                <span class="badge bg-warning text-dark px-2 py-2"><i class="bi bi-exclamation-triangle"></i> Màu vàng: Sắp hết hàng</span>
            </div>
        </div>

        <div id="tableContainer" class="position-relative" style="min-height:200px">
            <div class="d-flex justify-content-center p-5">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        let searchTimer;

        $(function () {
            loadTable();

            $('#searchInput').on('keyup', function () {
                clearTimeout(searchTimer);
                searchTimer = setTimeout(loadTable, 400);
            });
        });

        function loadTable() {
            $('#tableContainer').html('<div class="d-flex justify-content-center p-5"><div class="spinner-border text-primary" role="status"></div></div>');
            
            const q = {
                search: $('#searchInput').val()
            };

            $.get('/Managers/PartsTable', q)
                .done(function (html) {
                    $('#tableContainer').html(html);
                })
                .fail(function () {
                    $('#tableContainer').html('<div class="alert alert-danger">Lỗi khi tải dữ liệu.</div>');
                });
        }

        function showCreatePartModal() {
            $.get('/Managers/PartCreate')
                .done(function (html) {
                    $('#modalContainer').html(html);
                    const modal = new bootstrap.Modal(document.getElementById('partModal'));
                    modal.show();
                    setupAjaxForm(modal);
                });
        }

        function showEditPartModal(id) {
            $.get('/Managers/PartEdit/' + id)
                .done(function (html) {
                    $('#modalContainer').html(html);
                    const modal = new bootstrap.Modal(document.getElementById('partModal'));
                    modal.show();
                    setupAjaxForm(modal);
                });
        }

        function setupAjaxForm(modalInst) {
            const form = $('#partModal form');
            
            // Check if validator script is loaded, otherwise just proceed
            if ($.validator && $.validator.unobtrusive) {
                $.validator.unobtrusive.parse(form);
            }

            form.on('submit', function (e) {
                e.preventDefault();
                if ($.validator && !form.valid()) return;

                const btn = form.find('button[type="submit"]');
                const origText = btn.html();
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Đang lưu...');

                $.post(form.attr('action'), form.serialize())
                    .done(function (res) {
                        if (res.ok) {
                            form[0].reset();
                            modalInst.hide();
                            $('.modal-backdrop').remove();
                            showSuccessToast("Đã cập nhật phụ tùng thành công!");
                            loadTable();
                        } else {
                            $('#modalContainer').html(res);
                            setupAjaxForm(modalInst); // setup again on new DOM
                        }
                    })
                    .fail(function (xhr) {
                        if (xhr.status === 400 && xhr.responseText) {
                            if (xhr.responseText.includes('<form')) {
                                $('#modalContainer').html(xhr.responseText);
                                setupAjaxForm(modalInst);
                            } else {
                                alert(xhr.responseText);
                            }
                        } else {
                            alert("Có lỗi xảy ra, vui lòng thử lại.");
                        }
                        btn.prop('disabled', false).html(origText);
                    });
            });
        }
    </script>
}
