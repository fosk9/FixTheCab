@{
    ViewData["Title"] = "Báo Cáo (Dashboard)";
}

@await Html.PartialAsync("Partials/_ManagerNav")

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-speedometer2 me-2"></i>Báo Cáo Hiệu Quả Kinh Doanh</h2>
</div>

<div class="row g-4 mb-4">
    <!-- Revenue -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 file-border-left file-border-primary">
            <div class="card-body">
                <h6 class="text-muted text-uppercase mb-2">Tổng Doanh Thu</h6>
                <div class="d-flex align-items-center">
                    <div class="fs-3 fw-bold text-dark">@(((decimal)(ViewBag.TotalRevenue ?? 0)).ToString("N0")) đ</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Orders -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 file-border-left file-border-success">
            <div class="card-body">
                <h6 class="text-muted text-uppercase mb-2">Tổng Số Đơn Hàng</h6>
                <div class="d-flex align-items-center">
                    <div class="fs-3 fw-bold text-dark">@ViewBag.TotalOrders</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Jobs -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 file-border-left file-border-warning">
            <div class="card-body">
                <h6 class="text-muted text-uppercase mb-2">Xe Đang Chờ Phân Công</h6>
                <div class="d-flex align-items-center">
                    <div class="fs-3 fw-bold text-dark">@ViewBag.PendingJobs</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-5 text-center text-muted">
        <i class="bi bi-bar-chart-line" style="font-size: 3rem;"></i>
        <h5 class="mt-3">Biểu đồ chi tiết đang trong giai đoạn phát triển</h5>
        <p>Chọn các Tab bên trên để quản lý Kho Phụ Tùng, Lịch làm việc và Phân công.</p>
    </div>
</div>

<style>
    .file-border-left { border-left: 5px solid transparent !important; }
    .file-border-primary { border-left-color: #0d6efd !important; }
    .file-border-success { border-left-color: #198754 !important; }
    .file-border-warning { border-left-color: #ffc107 !important; }
</style>
