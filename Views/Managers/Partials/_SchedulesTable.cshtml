@model IEnumerable<PMPRacing.Models.WorkSchedule>

<div class="bg-light px-3 py-2 border-bottom text-center">
    <strong>Tuần: @(ViewBag.WeekStart?.ToString("dd/MM/yyyy")) - @(ViewBag.WeekEnd?.ToString("dd/MM/yyyy"))</strong>
</div>

@if (!Model.Any())
{
    <div class="p-5 text-center text-muted">
        <i class="bi bi-calendar-minus fs-1 d-block mb-3"></i>
        Chưa có lịch làm việc cho tuần này.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Ngày Làm Việc</th>
                    <th>Nhân Viên</th>
                    <th>Ca Làm (Shift)</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@item.WorkDate?.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="fw-bold text-primary">@item.Employee?.Name</span>
                            <small class="text-muted d-block">@item.Employee?.UserRoleEmployees.FirstOrDefault()?.Role?.RoleName</small>
                        </td>
                        <td>
                            @if (item.Shift == "morning") { <span class="badge bg-info text-dark">Sáng (Morning)</span> }
                            else { <span class="badge bg-warning text-dark">Chiều (Afternoon)</span> }
                        </td>
                        <td>
                            @if (item.CheckIn.HasValue) { <span class="text-success"><i class="bi bi-check-circle me-1"></i> @item.CheckIn?.ToString("HH:mm")</span> }
                            else { <span class="text-muted fst-italic">Chưa có</span> }
                        </td>
                        <td>
                            @if (item.CheckOut.HasValue) { <span class="text-secondary"><i class="bi bi-box-arrow-right me-1"></i> @item.CheckOut?.ToString("HH:mm")</span> }
                            else { <span class="text-muted fst-italic">Chưa có</span> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
