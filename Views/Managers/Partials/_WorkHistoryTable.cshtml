@model IEnumerable<WorkHistoryRowVm>

@if (!Model.Any())
{
    <div class="text-center text-muted py-4">
        <i class="fas fa-search fa-3x mb-3 text-light"></i>
        <div>Không có dữ liệu sửa chữa cho lựa chọn này.</div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Mã đơn</th>
                    <th>Biển số xe</th>
                    <th>Model xe</th>
                    <th>Khách hàng</th>
                    <th class="text-end pe-3">Giờ hoàn thành</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model)
                {
                    <tr>
                        <td class="ps-3 text-muted">#@row.OrderId</td>
                        <td><span class="badge bg-secondary">@row.LicensePlate</span></td>
                        <td>@row.BikeModel</td>
                        <td>@row.CustomerName</td>
                        <td class="text-end pe-3">@row.CompletedAt?.ToString("HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
