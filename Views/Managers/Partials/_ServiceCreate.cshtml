@model ServiceCreateVm

<div class="modal fade" id="serviceCreateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thêm dịch vụ mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/Managers/ServiceCreate" method="post" onsubmit="return handleServiceSubmit(this)">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Tên dịch vụ</label>
                        <input type="text" asp-for="ServiceName" class="form-control" placeholder="Ví dụ: Thay dầu, Bảo dưỡng toàn bộ...">
                        <span asp-validation-for="ServiceName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Đơn giá (VNĐ)</label>
                        <input type="number" asp-for="Price" class="form-control">
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary">Lưu dịch vụ</button>
                </div>
            </form>
        </div>
    </div>
</div>
