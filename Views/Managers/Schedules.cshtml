@{
    ViewData["Title"] = "Lịch Làm Việc";
}

@await Html.PartialAsync("Partials/_ManagerNav")

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-week me-2"></i>Lịch Làm Việc (Work Schedules)</h2>
    <div class="d-flex gap-2">
        <input type="date" id="dateFilter" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" onchange="loadTable()" />
    </div>
</div>

<div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body p-0">
        <div id="tableContainer" class="position-relative bg-white" style="min-height:200px">
            <div class="d-flex justify-content-center p-5">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            loadTable();
        });

        function loadTable() {
            var selectedDate = $('#dateFilter').val();
            $('#tableContainer').html('<div class="d-flex justify-content-center p-5"><div class="spinner-border text-primary" role="status"></div></div>');
            
            $.get('/Managers/SchedulesTable?date=' + selectedDate)
                .done(function (html) {
                    $('#tableContainer').html(html);
                });
        }
    </script>
}
