@model IEnumerable<InvoiceListVm>

@if (!Model.Any())
{
    <div class="text-center text-muted py-4">
        <i class="fas fa-file-invoice fa-3x mb-3"></i>
        <div>Không tìm thấy hóa đơn nào.</div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Mã hóa đơn</th>
                    <th>Biển số xe</th>
                    <th>Khách hàng</th>
                    <th>Xe</th>
                    <th>Trạng thái</th>
                    <th>Tổng tiền</th>
                    <th>Ngày tạo</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var invoice in Model)
                {
                    <tr>
                        <td><strong>#@invoice.OrderId</strong></td>
                        <td>
                            <span class="badge bg-secondary">@invoice.LicensePlate</span>
                        </td>
                        <td>@invoice.CustomerName</td>
                        <td>@invoice.BikeModel</td>
                        <td>
                            @{
                                var statusClass = invoice.Status switch
                                {
                                    "pending" => "bg-warning",
                                    "quoted" => "bg-info",
                                    "in_progress" => "bg-primary",
                                    "completed" => "bg-success",
                                    "cancelled" => "bg-danger",
                                    "awaiting_payment" => "bg-warning",
                                    "paid" => "bg-success",
                                    "payment_failed" => "bg-danger",
                                    _ => "bg-secondary"
                                };
                                var statusText = invoice.Status switch
                                {
                                    "pending" => "Chờ xử lý",
                                    "quoted" => "Đã báo giá",
                                    "in_progress" => "Đang xử lý",
                                    "completed" => "Hoàn thành",
                                    "cancelled" => "Đã hủy",
                                    "awaiting_payment" => "Chờ thanh toán",
                                    "paid" => "Đã thanh toán",
                                    "payment_failed" => "Thanh toán thất bại",
                                    _ => invoice.Status
                                };
                            }
                            <span class="badge @statusClass">@statusText</span>
                        </td>
                        <td><strong>@invoice.TotalPrice?.ToString("N0") VNĐ</strong></td>
                        <td>@invoice.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-primary" data-invoice-action="details" data-id="@invoice.OrderId" title="Chi tiết">
                                    <i class="fas fa-eye me-1"></i>Detail
                                </button>
                                @if (invoice.Status == "completed")
                                {
                                    <button class="btn btn-outline-info" data-invoice-action="generate" data-id="@invoice.OrderId" title="Lập hóa đơn">
                                        <i class="fas fa-file-invoice me-1"></i>Lập hóa đơn
                                    </button>
                                }
                                @if (invoice.Status == "awaiting_payment" || invoice.Status == "payment_failed")
                                {
                                    <button class="btn btn-outline-success" data-invoice-action="payment" data-id="@invoice.OrderId" data-amount="@invoice.TotalPrice" title="Thanh toán">
                                        <i class="fas fa-credit-card me-1"></i>Thanh toán
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted">
                Hiển thị trang @ViewBag.CurrentPage / @ViewBag.TotalPages (Tổng: @ViewBag.TotalCount hóa đơn)
            </div>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <button class="page-link" data-page="@(ViewBag.CurrentPage - 1)">Trước</button>
                        </li>
                    }
                    
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <button class="page-link" data-page="@i">@i</button>
                        </li>
                    }
                    
                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <button class="page-link" data-page="@(ViewBag.CurrentPage + 1)">Sau</button>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
}
