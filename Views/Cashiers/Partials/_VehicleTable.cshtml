@model IEnumerable<VehicleInfoVm>

@if (!Model.Any())
{
    <div class="text-center text-muted py-4">
        <i class="fas fa-motorcycle fa-3x mb-3"></i>
        <div>Không tìm thấy xe nào.</div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Biển số xe</th>
                    <th>Model xe</th>
                    <th>Khách hàng</th>
                    <th>Email</th>
                    <th>Điện thoại</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var vehicle in Model)
                {
                    <tr>
                        <td>
                            <span class="badge bg-primary fs-6">@vehicle.LicensePlate</span>
                        </td>
                        <td>@vehicle.BikeModel</td>
                        <td>@vehicle.CustomerName</td>
                        <td>@vehicle.CustomerEmail</td>
                        <td>@vehicle.CustomerPhone</td>
                        <td>
                            @{
                                var statusClass = vehicle.Status switch
                                {
                                    "in_service" => "bg-warning",
                                    "available" => "bg-success",
                                    _ => "bg-secondary"
                                };
                                var statusText = vehicle.Status switch
                                {
                                    "in_service" => "Đang sửa chữa",
                                    "available" => "Sẵn sàng",
                                    _ => vehicle.Status
                                };
                            }
                            <span class="badge @statusClass">@statusText</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
