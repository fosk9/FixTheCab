@model InvoiceDetailVm

<div class="row">
    <div class="col-md-6">
        <h6>Thông tin khách hàng</h6>
        <table class="table table-sm">
            <tr>
                <td><strong>Tên:</strong></td>
                <td>@Model.CustomerName</td>
            </tr>
            <tr>
                <td><strong>Email:</strong></td>
                <td>@Model.CustomerEmail</td>
            </tr>
            <tr>
                <td><strong>Điện thoại:</strong></td>
                <td>@Model.CustomerPhone</td>
            </tr>
        </table>
    </div>
    <div class="col-md-6">
        <h6>Thông tin xe</h6>
        <table class="table table-sm">
            <tr>
                <td><strong>Biển số:</strong></td>
                <td>@Model.LicensePlate</td>
            </tr>
            <tr>
                <td><strong>Model xe:</strong></td>
                <td>@Model.BikeModel</td>
            </tr>
            <tr>
                <td><strong>Trạng thái:</strong></td>
                <td>
                    @{
                        var statusClass = Model.Status switch
                        {
                            "pending" => "bg-warning",
                            "quoted" => "bg-info",
                            "in_progress" => "bg-primary",
                            "completed" => "bg-success",
                            "cancelled" => "bg-danger",
                            _ => "bg-secondary"
                        };
                        var statusText = Model.Status switch
                        {
                            "pending" => "Chờ xử lý",
                            "quoted" => "Đã báo giá",
                            "in_progress" => "Đang xử lý",
                            "completed" => "Hoàn thành",
                            "cancelled" => "Đã hủy",
                            _ => Model.Status
                        };
                    }
                    <span class="badge @statusClass">@statusText</span>
                </td>
            </tr>
            <tr>
                <td><strong>Kỹ thuật viên:</strong></td>
                <td>@Model.MechanicName</td>
            </tr>
        </table>
    </div>
</div>

<hr>

<h6>Chi tiết dịch vụ và phụ tùng</h6>
<div class="table-responsive">
    <table class="table table-sm">
        <thead class="table-light">
            <tr>
                <th>Loại</th>
                <th>Tên</th>
                <th>Mô tả</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        @if (item.ItemType == "Service")
                        {
                            <span class="badge bg-primary">Dịch vụ</span>
                        }
                        else
                        {
                            <span class="badge bg-info">Phụ tùng</span>
                        }
                    </td>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice.ToString("N0") VNĐ</td>
                    <td><strong>@item.TotalPrice.ToString("N0") VNĐ</strong></td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="table-active">
                <td colspan="5" class="text-end"><strong>Tổng cộng:</strong></td>
                <td><strong>@Model.TotalPrice?.ToString("N0") VNĐ</strong></td>
            </tr>
        </tfoot>
    </table>
</div>

<hr>

<div class="row">
    <div class="col-md-4">
        <small class="text-muted">Ngày tạo: @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</small>
    </div>
    @if (Model.StartedAt.HasValue)
    {
        <div class="col-md-4">
            <small class="text-muted">Bắt đầu: @Model.StartedAt?.ToString("dd/MM/yyyy HH:mm")</small>
        </div>
    }
    @if (Model.CompletedAt.HasValue)
    {
        <div class="col-md-4">
            <small class="text-muted">Hoàn thành: @Model.CompletedAt?.ToString("dd/MM/yyyy HH:mm")</small>
        </div>
    }
</div>
