@model CreateQuoteVm

<div class="row mb-3">
    <div class="col-md-6">
        <h6>Thông tin khách hàng</h6>
        <p><strong>Tên:</strong> @Model.CustomerName</p>
        <p><strong>Email:</strong> @Model.CustomerEmail</p>
    </div>
    <div class="col-md-6">
        <h6>Thông tin xe</h6>
        <p><strong>Biển số:</strong> @Model.LicensePlate</p>
        <p><strong>Model xe:</strong> @Model.BikeModel</p>
    </div>
</div>

<hr>

<h6>Chi tiết báo giá</h6>
<div class="table-responsive mb-3">
    <table class="table table-sm">
        <thead class="table-light">
            <tr>
                <th>Loại</th>
                <th>Tên</th>
                <th>Mô tả</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        @if (item.ItemType == "Service")
                        {
                            <span class="badge bg-primary">Dịch vụ</span>
                        }
                        else
                        {
                            <span class="badge bg-info">Phụ tùng</span>
                        }
                    </td>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice.ToString("N0") VNĐ</td>
                    <td><strong>@item.TotalPrice.ToString("N0") VNĐ</strong></td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="5" class="text-end"><strong>Chi phí nhân công:</strong></td>
                <td><strong>@Model.LaborCost.ToString("N0") VNĐ</strong></td>
            </tr>
            <tr class="table-active">
                <td colspan="5" class="text-end"><strong>Tổng cộng:</strong></td>
                <td><strong class="text-success">@Model.TotalCost.ToString("N0") VNĐ</strong></td>
            </tr>
        </tfoot>
    </table>
</div>

<form asp-action="SendQuote" method="post" data-invoice-form="sendQuote">
    @Html.AntiForgeryToken()
    <input type="hidden" name="orderId" value="@Model.OrderId" />
    
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Email khách hàng</label>
            <input type="email" class="form-control" name="customerEmail" value="@Model.CustomerEmail" required />
        </div>
        <div class="col-md-6">
            <label class="form-label">Ghi chú</label>
            <textarea class="form-control" name="notes" rows="1" placeholder="Ghi chú cho báo giá..."></textarea>
        </div>
    </div>
    
    <div class="mt-3 d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
        <button type="submit" class="btn btn-success">
            <i class="fas fa-paper-plane"></i> Gửi báo giá
        </button>
    </div>
</form>
