@{
    ViewData["Title"] = "Thu ngân";
}

<div class="p-4 bg-light border rounded mb-4">
    <h1 class="h4 mb-1">Thu ngân</h1>
    <p class="text-muted mb-0">Chào mừng, @User.Identity?.Name.</p>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-primary bg-opacity-10 rounded p-3">
                            <i class="fas fa-file-invoice-dollar fa-2x text-primary"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="card-title mb-1">Quản lý hóa đơn</h5>
                        <p class="card-text text-muted small">Xem và quản lý hóa đơn dịch vụ, tạo báo giá cho khách hàng</p>
                        <a href="@Url.Action("Invoices", "Cashiers")" class="btn btn-primary btn-sm">
                            <i class="fas fa-arrow-right"></i> Đi đến quản lý hóa đơn
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-success bg-opacity-10 rounded p-3">
                            <i class="fas fa-motorcycle fa-2x text-success"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="card-title mb-1">Nhập thông tin xe</h5>
                        <p class="card-text text-muted small">Quản lý thông tin xe và khách hàng mới</p>
                        <a href="@Url.Action("VehicleInfo", "Cashiers")" class="btn btn-success btn-sm">
                            <i class="fas fa-arrow-right"></i> Đi đến quản lý xe
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <div class="card h-100 border-danger">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-danger bg-opacity-10 rounded p-3">
                            <i class="fas fa-cart-plus fa-2x text-danger"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="card-title mb-1">Tạo hóa đơn mới</h5>
                        <p class="card-text text-muted small">Tạo hóa đơn dịch vụ mới với giỏ hàng, OTP và thanh toán PayOS</p>
                        <a href="@Url.Action("CreateInvoice", "Cashiers")" class="btn btn-danger btn-sm">
                            <i class="fas fa-arrow-right"></i> Tạo hóa đơn mới
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-warning bg-opacity-10 rounded p-3">
                            <i class="fas fa-money-bill-wave fa-2x text-warning"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="card-title mb-1">Thanh toán</h5>
                        <p class="card-text text-muted small">Xử lý thanh toán hóa đơn và quản lý giao dịch</p>
                        <a href="@Url.Action("Payments", "Cashiers")" class="btn btn-warning btn-sm">
                            <i class="fas fa-arrow-right"></i> Đi đến thanh toán
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
