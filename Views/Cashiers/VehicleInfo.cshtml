@{
    ViewData["Title"] = "Nhập thông tin xe";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h4 mb-0">Nhập thông tin xe</h1>
        <div class="text-muted">Quản lý thông tin xe và khách hàng.</div>
    </div>
    <button class="btn btn-primary" type="button" id="btnCreateVehicle">Thêm xe mới</button>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-8">
                <label class="form-label">Tìm kiếm</label>
                <div class="input-group">
                    <input type="text" class="form-control" id="vehicleSearchInput" placeholder="Tìm theo biển số, tên khách hàng, model xe...">
                    <button class="btn btn-outline-secondary" type="button" id="clearVehicleSearch">Xóa</button>
                </div>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button class="btn btn-primary w-100" type="button" id="applyVehicleFilters">Tìm kiếm</button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div id="vehicleTableWrap" class="p-3">
            <div class="text-muted">Đang tải...</div>
        </div>
    </div>
</div>

<div class="modal fade" id="vehicleOverlay" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="vehicleOverlayTitle">...</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="vehicleOverlayBody">
                ...
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const vehicleOverlayEl = document.getElementById('vehicleOverlay');
        const vehicleOverlay = new bootstrap.Modal(vehicleOverlayEl);

        async function loadVehicleTable(search = "") {
            const wrap = document.getElementById('vehicleTableWrap');
            const params = new URLSearchParams({ search });
            const res = await fetch('@Url.Action("VehicleTable","Cashiers")' + '?' + params.toString(), { headers: { 'X-Requested-With': 'fetch' } });
            wrap.innerHTML = await res.text();
        }

        async function openVehicleOverlay(title, url) {
            document.getElementById('vehicleOverlayTitle').innerText = title;
            document.getElementById('vehicleOverlayBody').innerHTML = '<div class="text-muted">Đang tải...</div>';
            vehicleOverlay.show();
            const res = await fetch(url, { headers: { 'X-Requested-With': 'fetch' } });
            document.getElementById('vehicleOverlayBody').innerHTML = await res.text();
        }

        function formUrlEncoded(obj) {
            return Object.keys(obj).map(k => encodeURIComponent(k) + '=' + encodeURIComponent(obj[k] ?? '')).join('&');
        }

        // Search functionality
        document.getElementById('clearVehicleSearch').addEventListener('click', () => {
            document.getElementById('vehicleSearchInput').value = '';
            loadVehicleTable();
        });

        document.getElementById('applyVehicleFilters').addEventListener('click', () => {
            const search = document.getElementById('vehicleSearchInput').value;
            loadVehicleTable(search);
        });

        // Real-time search on Enter key
        document.getElementById('vehicleSearchInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                const search = e.target.value;
                loadVehicleTable(search);
            }
        });

        // Create vehicle button
        document.getElementById('btnCreateVehicle').addEventListener('click', () => {
            openVehicleOverlay('Thêm xe mới', '@Url.Action("VehicleCreate","Cashiers")');
        });

        // Handle form submissions
        document.addEventListener('submit', async (e) => {
            const form = e.target;
            if (!form.matches('[data-vehicle-form]')) return;
            e.preventDefault();

            const action = form.getAttribute('data-vehicle-form');
            const data = new FormData(form);

            if (action === 'create') {
                const res = await fetch(form.action, { method: 'POST', body: data });
                const json = await res.json();
                if (json.ok) {
                    vehicleOverlay.hide();
                    loadVehicleTable();
                } else {
                    // If validation failed, reload the form with errors
                    const text = await res.text();
                    document.getElementById('vehicleOverlayBody').innerHTML = text;
                }
            }
        });

        loadVehicleTable();
    </script>
}
