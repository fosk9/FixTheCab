@{
    ViewData["Title"] = "Giả lập thanh toán";
    var orderId = ViewBag.OrderId;
    var amount = ViewBag.Amount;
    var customerName = ViewBag.CustomerName;
    var description = ViewBag.Description;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0"><i class="fas fa-credit-card me-2"></i>Trang thanh toán giả lập</h4>
                    <small class="text-white-50">Chỉ dùng để test</small>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning mb-4">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Đây là trang thanh toán giả lập để test.</strong>
                        <br>Bạn có thể chọn thanh toán thành công hoặc thất bại.
                    </div>
                    
                    <div class="mb-4">
                        <h5 class="text-muted mb-3">Thông tin thanh toán</h5>
                        <table class="table table-borderless">
                            <tr>
                                <td class="text-muted">Mã đơn hàng:</td>
                                <td class="text-end"><strong>#@orderId</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Khách hàng:</td>
                                <td class="text-end"><strong>@customerName</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Mô tả:</td>
                                <td class="text-end">@description</td>
                            </tr>
                            <tr class="border-top">
                                <td class="text-muted fs-5">Số tiền:</td>
                                <td class="text-end fs-4 text-success"><strong>@amount.ToString("N0") VNĐ</strong></td>
                            </tr>
                        </table>
                    </div>
                    
                    <div class="d-grid gap-3">
                        <form method="post" action="@Url.Action("ConfirmPaymentSuccess", "Cashiers")" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="orderId" value="@orderId" />
                            <button type="submit" class="btn btn-success btn-lg w-100">
                                <i class="fas fa-check-circle me-2"></i>Giả lập thanh toán THÀNH CÔNG
                            </button>
                        </form>
                        
                        <form method="post" action="@Url.Action("ConfirmPaymentFailed", "Cashiers")" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="orderId" value="@orderId" />
                            <button type="submit" class="btn btn-danger btn-lg w-100">
                                <i class="fas fa-times-circle me-2"></i>Giả lập thanh toán THẤT BẠI
                            </button>
                        </form>
                        
                        <a href="@Url.Action("CreateInvoice", "Cashiers")" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại
                        </a>
                    </div>
                </div>
                <div class="card-footer text-center text-muted">
                    <small><i class="fas fa-flask me-1"></i>Môi trường test - Không thanh toán thật</small>
                </div>
            </div>
        </div>
    </div>
</div>
