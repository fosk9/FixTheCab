@{
    ViewData["Title"] = "Thanh toán";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h4 mb-0">Thanh toán</h1>
        <div class="text-muted">Quản lý thanh toán hóa đơn dịch vụ.</div>
    </div>
    <a href="@Url.Action("Index", "Cashiers")" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Tìm kiếm</label>
                <div class="input-group">
                    <input type="text" class="form-control" id="paymentSearchInput" placeholder="Tìm theo biển số, tên khách hàng...">
                    <button class="btn btn-outline-secondary" type="button" id="clearPaymentSearch">Xóa</button>
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Trạng thái</label>
                <select class="form-select" id="paymentStatusFilter">
                    <option value="">Tất cả trạng thái</option>
                    <option value="completed">Đã thanh toán</option>
                    <option value="pending">Chờ thanh toán</option>
                    <option value="refunded">Đã hoàn tiền</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary w-100" type="button" id="applyPaymentFilters">Lọc</button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div id="paymentTableWrap" class="p-3">
            <div class="text-muted">Đang tải...</div>
        </div>
    </div>
</div>

<div class="modal fade" id="paymentOverlay" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="paymentOverlayTitle">...</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="paymentOverlayBody">
                ...
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const paymentOverlayEl = document.getElementById('paymentOverlay');
        const paymentOverlay = new bootstrap.Modal(paymentOverlayEl);

        async function loadPaymentTable(search = "", status = "") {
            const wrap = document.getElementById('paymentTableWrap');
            const params = new URLSearchParams({ search, status });
            const res = await fetch('@Url.Action("PaymentTable","Cashiers")' + '?' + params.toString(), { headers: { 'X-Requested-With': 'fetch' } });
            wrap.innerHTML = await res.text();
        }

        async function openPaymentOverlay(title, url) {
            document.getElementById('paymentOverlayTitle').innerText = title;
            document.getElementById('paymentOverlayBody').innerHTML = '<div class="text-muted">Đang tải...</div>';
            paymentOverlay.show();
            const res = await fetch(url, { headers: { 'X-Requested-With': 'fetch' } });
            document.getElementById('paymentOverlayBody').innerHTML = await res.text();
        }

        // Search and filter functionality
        document.getElementById('clearPaymentSearch').addEventListener('click', () => {
            document.getElementById('paymentSearchInput').value = '';
            document.getElementById('paymentStatusFilter').value = '';
            loadPaymentTable();
        });

        document.getElementById('applyPaymentFilters').addEventListener('click', () => {
            const search = document.getElementById('paymentSearchInput').value;
            const status = document.getElementById('paymentStatusFilter').value;
            loadPaymentTable(search, status);
        });

        // Real-time search on Enter key
        document.getElementById('paymentSearchInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                const search = e.target.value;
                const status = document.getElementById('paymentStatusFilter').value;
                loadPaymentTable(search, status);
            }
        });

        // Auto-apply filters on dropdown change
        document.getElementById('paymentStatusFilter').addEventListener('change', () => {
            const search = document.getElementById('paymentSearchInput').value;
            const status = document.getElementById('paymentStatusFilter').value;
            loadPaymentTable(search, status);
        });

        // Handle action buttons
        document.addEventListener('click', async (e) => {
            const btn = e.target.closest('[data-payment-action]');
            if (!btn) return;
            const action = btn.getAttribute('data-payment-action');
            const id = btn.getAttribute('data-id');

            if (action === 'pay') {
                await openPaymentOverlay('Thanh toán', '@Url.Action("CreatePayment","Cashiers")' + '?orderId=' + id);
            }
        });

        // Handle form submissions
        document.addEventListener('submit', async (e) => {
            const form = e.target;
            if (!form.matches('[data-payment-form]')) return;
            e.preventDefault();

            const action = form.getAttribute('data-payment-form');
            const data = new FormData(form);

            if (action === 'process') {
                const res = await fetch(form.action, { method: 'POST', body: data });
                const json = await res.json();
                if (json.ok) {
                    paymentOverlay.hide();
                    loadPaymentTable();
                } else {
                    alert('Thanh toán thất bại. Vui lòng thử lại.');
                }
            }
        });

        loadPaymentTable();
    </script>
}
